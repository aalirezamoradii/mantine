{
  "name": "mantine-dates-jalali",
  "version": "7.12.3",
  "description": "Calendars, date and time pickers based on Mantine components",
  "homepage": "https://github.com/aalirezamoradii/mantine",
  "license": "MIT",
  "author": "Alireza Moradi <aalirezamoradii@gmail.com>",
  "keywords": [
    "calendar",
    "components",
    "date",
    "frontend",
    "library",
    "next",
    "nextjs",
    "picker",
    "react",
    "time",
    "ui",
    "ui-kit",
    "jalali"
  ],
  "sideEffects": [
    "*.css"
  ],
  "main": "./cjs/index.cjs",
  "module": "./esm/index.mjs",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./lib/index.d.mts",
        "default": "./esm/index.mjs"
      },
      "require": {
        "types": "./lib/index.d.ts",
        "default": "./cjs/index.cjs"
      }
    },
    "./styles.css": "./styles.css",
    "./styles.layer.css": "./styles.layer.css"
  },
  "repository": {
    "url": "https://github.com/aalirezamoradii/mantine.git",
    "type": "git"
  },
  "peerDependencies": {
    "@mantine/core": "7.12.1",
    "@mantine/hooks": "7.12.1",
    "dayjs": ">=1.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "dependencies": {
    "@zoomit/dayjs-jalali-plugin": "^0.0.7",
    "clsx": "^2.1.1"
  },
  "devDependencies": {
    "@mantine-tests/core": "workspace:*",
    "@mantine-tests/dates": "workspace:*",
    "@mantine/core": "workspace:*",
    "@mantine/hooks": "workspace:*"
  }
}
